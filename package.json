{
  "name": "granola-cli",
  "version": "0.1.0",
  "description": "CLI for Granola meeting notes API",
  "private": true,
  "type": "module",
  "bin": {
    "granola": "./dist/main.mjs"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "build:esm": "tsdown --config tsdown.dev.config.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/main.ts",
    "lint": "biome check",
    "format": "biome check --write",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "bash scripts/version.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@tsdown/exe": "0.22.0",
    "@types/node": "^25.0.0",
    "tsdown": "0.22.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@bomb.sh/tab": "^0.0.15",
    "@drizzle-team/brocli": "^0.12.0"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@10.6.4"
}
